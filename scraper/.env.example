# =============================
# SeekSpider Environment Sample
# Save as: scraper/.env
# Local development only.
# CI/CD and production DO NOT read this file; they use runtime environment vars/secrets.
# =============================

# -----------------------------
# Database mode (recommended local)
# -----------------------------
DATABASE_ENGINE=sqlite
SQLITE_DB_PATH=./data/seek_jobs.sqlite3
DATABASE_TABLE=seek_jobs

# -----------------------------
# PostgreSQL compatibility mode (optional)
# Uncomment/use when DATABASE_ENGINE=postgres
# -----------------------------
# POSTGRESQL_HOST=localhost
# POSTGRESQL_PORT=5432
# POSTGRESQL_USER=seekuser
# POSTGRESQL_PASSWORD=seekpass
# POSTGRESQL_DATABASE=seekdb
# POSTGRESQL_TABLE=seek_jobs

# Backward-compatible aliases are also supported:
# POSTGRES_HOST / POSTGRES_PORT / POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB / POSTGRES_TABLE

# -----------------------------
# AI API (optional, for post-processing/backfill workflows)
# -----------------------------
# AI_API_KEYS=key1,key2
# AI_API_URL=https://api.siliconflow.cn/v1/chat/completions
# AI_MODEL=deepseek-ai/DeepSeek-V2.5
